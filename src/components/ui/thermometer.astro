---
import { sauces } from "../../data/sauces";
import type { Sauce } from "../../types";

const levels = [0, 1, 2, 3, 4, 5];
const levelColors = [
  "bg-emerald-500", // 0 (Nada)
  "bg-yellow-400", // 1 (Poco)
  "bg-orange-400", // 2 (Medio)
  "bg-orange-600", // 3 (Alto)
  "bg-red-600", // 4 (Bravo)
  "bg-red-950 border border-red-500", // 5 (Infierno)
];

const levelNames = ["Cero", "Poco", "Medio", "Alto", "Bravo", "Infierno"];
---

<div
  class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-6 my-10 backdrop-blur-sm relative overflow-hidden group"
>
  <!-- Industrial background detail -->
  <div
    class="absolute top-0 right-0 w-32 h-32 bg-moto-red/5 blur-[80px] -z-10 group-hover:bg-moto-red/10 transition-colors duration-700"
  >
  </div>

  <div class="flex flex-col md:flex-row gap-8 items-center md:items-stretch">
    <!-- Thermometer Visualization Container -->
    <div class="flex items-center gap-1 sm:gap-3 relative pb-6 md:pb-0">
      <!-- Text Labels -->
      <div class="flex flex-col h-64 py-1 z-10 w-20 sm:w-24">
        {
          levels
            .slice()
            .reverse()
            .map((level) => {
              const textColors = [
                "text-emerald-500",
                "text-yellow-400",
                "text-orange-400",
                "text-orange-600",
                "text-red-600",
                "text-red-500",
              ];
              const bgColors = [
                "bg-emerald-500",
                "bg-yellow-400",
                "bg-orange-400",
                "bg-orange-600",
                "bg-red-600",
                "bg-red-500",
              ];
              return (
                <div class="flex-1 flex items-center justify-end">
                  <span
                    class={`text-[10px] sm:text-xs font-black uppercase tracking-wider text-right leading-none ${textColors[level]} ${level === 5 ? "animate-pulse drop-shadow-[0_0_5px_rgba(239,68,68,0.5)]" : ""}`}
                  >
                    {levelNames[level]}
                  </span>
                  <div
                    class={`w-2 sm:w-3 h-0.5 rounded-full ml-1.5 sm:ml-2 ${bgColors[level]}`}
                  />
                </div>
              );
            })
        }
      </div>

      <!-- Thermometer Tube -->
      <div
        class="relative flex flex-col items-center justify-between h-64 w-12 bg-neutral-800 rounded-full border-4 border-neutral-700 shadow-inner p-1"
      >
        <div
          class="w-full h-full rounded-full shadow-lg relative flex flex-col overflow-hidden"
          style="background: linear-gradient(to top, #10b981 0%, #facc15 20%, #fb923c 40%, #ea580c 60%, #dc2626 80%);"
        >
          {
            levels
              .slice()
              .reverse()
              .map((level) => (
                <div
                  class="w-full flex-1 cursor-help"
                  title={levelNames[level]}
                />
              ))
          }
        </div>
        <!-- Bulb at the bottom -->
        <div
          class="absolute -bottom-4 w-16 h-16 bg-neutral-800 rounded-full border-4 border-neutral-700 flex items-center justify-center overflow-hidden z-10"
        >
          <div
            class="w-10 h-10 bg-emerald-500 rounded-full animate-pulse shadow-[0_0_20px_rgba(16,185,129,0.6)]"
          >
          </div>
        </div>
      </div>
    </div>

    <!-- Sauce List -->
    <div class="flex-grow">
      <div class="mb-4">
        <h3
          class="text-2xl font-black text-moto-white uppercase italic tracking-tighter flex items-center gap-2"
        >
          <span class="text-moto-red">Grado</span> de Picante
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-moto-red inline-block"
            ><path
              d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.256 1.189-3.103a2.5 2.5 0 0 0 3.311 3.103Z"
            ></path></svg
          >
        </h3>
        <p class="text-neutral-400 text-sm">
          Escoge tu nivel de aventura en cada mordida.
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        {
          sauces.map((sauce) => (
            <div class="bg-neutral-800/40 p-3 rounded-lg border border-neutral-700/50 hover:border-moto-red/30 transition-all group/item">
              <div class="flex items-center justify-between mb-1">
                <span class="text-moto-white font-bold text-xs uppercase truncate pr-1">
                  {sauce.name}
                </span>
                <div class="flex gap-0.5">
                  {[...Array(5)].map((_, i) => (
                    <div
                      class={`w-1.5 h-1.5 rounded-full ${i < (sauce.level === 5 ? 5 : sauce.level) ? levelColors[sauce.level] : "bg-neutral-700"} ${sauce.level === 5 ? "animate-pulse" : ""}`}
                    />
                  ))}
                </div>
              </div>
              {sauce.description && (
                <p class="text-[10px] text-neutral-500 line-clamp-1">
                  {sauce.description}
                </p>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</div>
