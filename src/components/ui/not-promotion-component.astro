---
import { Icon } from "astro-icon/components";

const {
  title = "Sin promociones activas",
  description = "Por el momento no tenemos promociones disponibles. ¡Vuelve pronto para descubrir nuevas ofertas!",
} = Astro.props;
---

<div
  class="w-full flex flex-col items-center justify-center py-16 px-4 text-center bg-neutral-primary-soft/20 border-2 border-dashed border-neutral-700 rounded-base"
>
  <div class="bg-neutral-800/50 p-6 rounded-full mb-6">
    <Icon name="fa6-solid:road" class="size-12 text-neutral-500" />
  </div>
  <h3
    class="text-2xl font-bold uppercase italic tracking-wide text-moto-white mb-2"
  >
    {title}
  </h3>
  <p class="text-body text-neutral-400 max-w-md mx-auto">
    {description}
  </p>
</div>
