---
import { promos } from "../data/menu";
import TitleSection from "../components/ui/title-section.astro";
import Carousel from "../components/ui/carrousel";
import NotPromotionComponent from "../components/ui/not-promotion-component.astro";
---

<section id="promos" class="py-20 bg-moto-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {
      promos.length === 0 ? (
        <NotPromotionComponent
          title="Promociones"
          description="Por el momento no tenemos promociones disponibles. ¡Vuelve pronto para descubrir nuevas ofertas!"
        />
      ) : (
        <>
          <TitleSection title="Promociones" orientation="center" />
          <div class="mb-16">
            <Carousel client:load cardData={promos} />
          </div>
        </>
      )
    }
  </div>
</section>
