---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/logo.png" />
    <link
      href="https://fonts.googleapis.com/icon?family=Material+Icons"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="La Estación 28 - Las mejores hamburguesas y alitas con estilo biker. Visítanos o ordena en línea. Hamburgerías en Xochimilco, CDMX." />
    <meta name="keywords" content="hamburguesas, alitas, biker, comida, Xochimilco, CDMX, delivery, estacion 28" />
    <meta name="author" content="La Estación 28" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://estacion28.com/" />
    <meta property="og:title" content="La Estación 28 - Hamburgesas y Alitas con Attitude" />
    <meta property="og:description" content="Las mejores hamburguesas para los amantes del asfalto. Visítanos en Xochimilco o ordena en línea." />
    <meta property="og:image" content="/og-image.svg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://estacion28.com/" />
    <meta property="twitter:title" content="La Estación 28 - Hamburgesas y Alitas con Attitude" />
    <meta property="twitter:description" content="Las mejores hamburguesas para los amantes del asfalto. Visítanos en Xochimilco o ordena en línea." />
    <meta property="twitter:image" content="/og-image.svg" />

    <title>Estacion 28</title>
  </head>
  <body class="bg-moto-black text-moto-white font-sans antialiased">
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    scroll-behavior: smooth;
  }
</style>
